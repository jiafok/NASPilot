# === NASPilot 环境变量 ===
# 复制此文件为 .env 并修改

# 安全密钥（生产环境务必修改！）
SECRET_KEY=change-me-to-a-random-string-at-least-32-chars

# 管理员初始密码（首次启动时创建，之后无效）
ADMIN_PASSWORD=admin123

# 数据库路径
DATABASE_URL=sqlite+aiosqlite:////app/data/naspilot.db

# 日志级别: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# 时区
TZ=Asia/Shanghai
